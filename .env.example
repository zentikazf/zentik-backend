# ── APP ──────────────────────────────────────────
NODE_ENV=production
PORT=3001
API_URL=https://your-api.railway.app
WEB_URL=https://your-app.vercel.app
API_PREFIX=/api/v1

# ── DATABASE ────────────────────────────────────
DATABASE_URL=postgresql://user:pass@host:5432/zentik?schema=public

# ── REDIS ───────────────────────────────────────
REDIS_URL=redis://default:pass@host:6379

# ── AUTH ────────────────────────────────────────
BETTER_AUTH_SECRET=generate-a-32-char-secret-here!!
BETTER_AUTH_URL=https://your-api.railway.app

# ── STORAGE (S3/R2/MinIO) ──────────────────────
STORAGE_ENDPOINT=https://your-s3-endpoint.com
STORAGE_ACCESS_KEY=your-access-key
STORAGE_SECRET_KEY=your-secret-key
STORAGE_BUCKET=zentik-files
STORAGE_REGION=us-east-1

# ── EMAIL (optional) ───────────────────────────
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@zentik.app
SENDGRID_FROM_NAME=Zentik

# ── OAUTH (optional) ───────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── MONITORING (optional) ──────────────────────
SENTRY_DSN=
LOG_LEVEL=info
